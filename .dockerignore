# ── Version control ───────────────────────────────────────────────────────────
.git
.gitignore

# ── Secrets / env ─────────────────────────────────────────────────────────────
.env
.env.*

# ── Python runtime artifacts ──────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.coverage
htmlcov/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/

# ── Frontend (deployed separately on Vercel) ──────────────────────────────────
frontend/

# ── Tests (not needed in production image) ───────────────────────────────────
tests/

# ── Generated / ephemeral files ───────────────────────────────────────────────
output/*.pdf
output/*.json
graphify-out/
tmp/
*.log
*.pid

# ── Dev-only artifacts ────────────────────────────────────────────────────────
.playwright-mcp/
.antigravitycli/
.claude/
plans/
docs/
screenshots/
CLAUDE.md
notes.md
notes.txt
format.json
test.pdf

# ── Deployment configs for other platforms ────────────────────────────────────
render.yaml

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.code-workspace
.DS_Store
Thumbs.db
