# ── Groq (LLM) ───────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
# Recommended: llama-3.3-70b-versatile (or llama-3.1-8b-instant / mixtral-8x7b-32768)
GROQ_MODEL=llama-3.1-8b-instant
# ── LangSmith (tracing — required, app warns but won't crash without it) ─────
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=soundreverse-v1
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── Supabase (job queue / state) ──────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Modal MCP (audio analysis — upload path only; demo tracks use cache/) ────
SONIC_MCP_URL=https://your-modal-app--audio-sonic-mcp-mcp-server.modal.run

# ── CORS (set to your Vercel frontend URL in production) ─────────────────────
# Dev default (localhost:5173/5174) is baked into api.py — only set this in prod
# CORS_ORIGINS=https://your-app.vercel.app

# ── Output / upload directories (overridden by render.yaml in production) ────
# OUTPUT_DIR=/tmp/soundreverse/outputs
# UPLOAD_DIR=/tmp/soundreverse/uploads
